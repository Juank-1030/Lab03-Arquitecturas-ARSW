@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 2.3 - Room Management TCP Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":RoomClient" as RoomClient
}

package "«subsystem» RoomServer" {
  component ":RoomServer" as RoomServer
  component ":RoomRepository" as RoomRepo
  component ":Room" as RoomModel
}

' Provided interfaces
interface "TCP :36000" as ITcp

' Conexiones (ball = provee, socket = requiere)
' RoomServer provee TCP
RoomServer --( ITcp

' RoomClient requiere TCP
RoomClient -- ITcp

' RoomServer usa repositorio
RoomServer --> RoomRepo : <<use>>

' Repositorio contiene modelo
RoomRepo --> RoomModel : <<use>>

@enduml
