@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 3.3 - Room Management HTTP Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":Browser / curl" as Browser
}

package "«subsystem» RoomHttpServer" {
  component ":RoomHttpServer" as HttpServer
  component ":RoomRepository" as RoomRepo
  component ":Room" as RoomModel
}

' Provided interfaces
interface "HTTP :8081" as IHttp

' Conexiones (ball = provee, socket = requiere)
' RoomHttpServer provee HTTP
HttpServer --( IHttp

' Browser requiere HTTP
Browser -- IHttp

' HttpServer usa repositorio
HttpServer --> RoomRepo : <<use>>

' Repositorio contiene modelo
RoomRepo --> RoomModel : <<use>>

@enduml
