@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 4.3 - Lab Inventory RMI Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":EquipmentRmiClient" as Client
}

package "«subsystem» EquipmentServer" {
  component ":EquipmentRmiServer" as Server
  component ":EquipmentServiceImpl" as ServiceImpl
  component ":EquipmentService\n(interface)" as ServiceInterface
  component ":Equipment" as EquipModel
}

' Provided interfaces
interface "RMI Registry :24000\n(equipmentService)" as IRmi

' Conexiones (ball = provee, socket = requiere)
' Server provee RMI
Server --( IRmi

' Client requiere RMI
Client -- IRmi

' Server registra implementacion
Server --> ServiceImpl : <<bind>>

' ServiceImpl implementa interfaz remota
ServiceImpl --> ServiceInterface : extends UnicastRemoteObject\nimplements EquipmentService

' ServiceImpl contiene BD interna (Map)
ServiceImpl --> EquipModel : <<in-memory map>>

@enduml
