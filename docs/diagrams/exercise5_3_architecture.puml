@startuml
title Exercise 5.3 - Wellness gRPC Architecture

package "Runtime" {
  participant "WellnessClient" as client
  participant "gRPC Channel\n(:50061)" as channel
  participant "WellnessServer" as server
  database "Appointments\n(in memory)" as repo

  client -> channel : requestAppointment(Request)\ncancelAppointment(Cancel)\ngetAppointments(Student)
  channel -> server : HTTP/2\nprotobuf binary
  server -> repo : create / cancel / query
  repo --> server : result
  server --> channel : AppointmentResponse
  channel --> client : deserialized response
}

legend right
  Service: AppointmentService
  3 RPCs: request/cancel/get
  Enums: ServiceType, Status
  Single gRPC server
endlegend

@enduml