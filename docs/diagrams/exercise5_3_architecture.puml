@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 5.3 - Wellness gRPC Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":WellnessGrpcClient" as Client
}

package "«subsystem» WellnessGrpcServer" {
  component ":WellnessServiceImpl" as ServiceImpl
  component ":appointment.proto\n(3 RPCs)" as ProtoFile
  database ":Appointments\n(in memory)" as AppDb
}

' Provided interfaces
interface "gRPC :50061\nAppointmentService" as IGrpc

' Conexiones (ball = provee, socket = requiere)
' ServiceImpl provee gRPC
ServiceImpl --( IGrpc

' Client requiere gRPC
Client -- IGrpc

' Proto define el contrato
ProtoFile --> IGrpc : <<defines>>

' ServiceImpl usa BD
ServiceImpl --> AppDb : <<use>>

@enduml
