@startuml
!theme plain

title Exercise 6.3 - Wellness Microservices Architecture

skinparam component {
  BackgroundColor White
  BorderColor Black
  FontSize 12
}

skinparam database {
  BackgroundColor LightYellow
  BorderColor DarkGoldenRod
}

skinparam node {
  BackgroundColor LightBlue
  BorderColor Blue
}

package "WellnessClient (Portfolio)" as CLIENT {
  [Appointment Stub] as CAS
  [Medical Stub] as CMS
  [Gym Stub] as CGS
  [Recreation Stub] as CRS
}

node "AppointmentService\nPort 50061" as APPS {
  database "Appointments\n(in-memory)" as DB_A
  [AppointmentServiceImpl] as ASI
  rectangle "RPCs:" as APPS_RPC {
    together {
      (RequestAppointment)
      (CancelAppointment)
      (GetAppointments)
      (DeleteAppointment)
      (UpdateAppointmentDate)
    }
  }
  ASI --> DB_A
  ASI --> APPS_RPC
}

node "MedicalService\nPort 50062" as MEDS {
  database "Specialties\n(in-memory)" as DB_M
  [MedicalServiceImpl] as MSI
  rectangle "RPCs:" as MEDS_RPC {
    together {
      (GetSpecialty)
      (ListSpecialties)
      (AddSpecialty)
      (RemoveSpecialty)
    }
  }
  MSI --> DB_M
  MSI --> MEDS_RPC
}

node "GymService\nPort 50063" as GYMS {
  database "Sessions\n(in-memory)" as DB_G
  [GymServiceImpl] as GSI
  rectangle "RPCs:" as GYMS_RPC {
    together {
      (ReserveSession)
      (GetSessions)
      (CancelSession)
      (GetAllSessions)
    }
  }
  GSI --> DB_G
  GSI --> GYMS_RPC
}

node "RecreationService\nPort 50064" as RECS {
  database "Resources\n(in-memory)" as DB_R
  [RecreationServiceImpl] as RSI
  rectangle "RPCs:" as RECS_RPC {
    together {
      (ReserveResource)
      (ListResources)
      (ReturnResource)
      (AddResource)
    }
  }
  RSI --> DB_R
  RSI --> RECS_RPC
}

CAS -down-> APPS : gRPC channel
CMS -down-> MEDS : gRPC channel
CGS -down-> GYMS : gRPC channel
CRS -down-> RECS : gRPC channel

legend right
  Client-Side Discovery pattern
  4 independent gRPC servers
  Each with its own .proto contract
  17 RPCs total (5+4+4+4)
endlegend

@enduml
