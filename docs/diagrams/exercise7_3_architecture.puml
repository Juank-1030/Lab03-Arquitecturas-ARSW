@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 7.3 - WellnessGateway Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":Browser / curl" as Browser
}

package "«subsystem» WellnessGateway" {
  component ":WellnessGateway\n(HTTP :8083)" as Gateway
  component ":AppointmentStub" as AppStub
  component ":MedicalStub" as MedStub
  component ":GymStub" as GymStub
  component ":RecStub" as RecStub
}

package "«subsystem» AppointmentService" {
  component ":AppointmentServiceImpl" as AppSvc
  database ":Appointments" as AppDb
}

package "«subsystem» MedicalService" {
  component ":MedicalServiceImpl" as MedSvc
  database ":Specialties" as MedDb
}

package "«subsystem» GymService" {
  component ":GymServiceImpl" as GymSvc
  database ":Sessions" as GymDb
}

package "«subsystem» RecreationService" {
  component ":RecreationServiceImpl" as RecSvc
  database ":Resources" as RecDb
}

' Provided interfaces
interface "HTTP :8083" as IHttp
interface "gRPC :50061\nAppointmentService" as IApp
interface "gRPC :50062\nMedicalService" as IMed
interface "gRPC :50063\nGymService" as IGym
interface "gRPC :50064\nRecreationService" as IRec

' Conexiones (ball = provee, socket = requiere)
' Gateway provee HTTP
Gateway --( IHttp

' Browser requiere HTTP
Browser -- IHttp

' Microservicios proveen gRPC
AppSvc --( IApp
MedSvc --( IMed
GymSvc --( IGym
RecSvc --( IRec

' Gateway requiere los 4 servicios
AppStub -- IApp
MedStub -- IMed
GymStub -- IGym
RecStub -- IRec

' Gateway usa stubs internamente
Gateway --> AppStub : <<use>>
Gateway --> MedStub : <<use>>
Gateway --> GymStub : <<use>>
Gateway --> RecStub : <<use>>

' Servidores usan sus BD
AppSvc --> AppDb : <<use>>
MedSvc --> MedDb : <<use>>
GymSvc --> GymDb : <<use>>
RecSvc --> RecDb : <<use>>

@enduml
