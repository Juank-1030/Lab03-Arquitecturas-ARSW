@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Exercise 8 - ECICIENCIA Platform Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":Browser / curl" as Browser
}

package "«subsystem» ECICIENCIA Gateway" {
  component ":EcicienciaGateway\n(HTTP :8090)" as Gateway
  component ":AttendeeStub" as AttStub
  component ":AgendaStub" as AgStub
  component ":WorkshopStub" as WkStub
}

package "«subsystem» AttendeeService" {
  component ":AttendeeServiceImpl\n(3 RPCs)" as AttSvc
  database ":Attendees Map" as AttDb
}

package "«subsystem» AgendaService" {
  component ":AgendaServiceImpl\n(3 RPCs)" as AgSvc
  database ":Activities Map" as AgDb
}

package "«subsystem» WorkshopService" {
  component ":WorkshopServiceImpl\n(4 RPCs)" as WkSvc
  database ":Reservations Map" as WkDb
}

' Provided interfaces
interface "HTTP :8090" as IHttp
interface "gRPC :8091\nAttendeeService" as IAtt
interface "gRPC :8092\nAgendaService" as IAg
interface "gRPC :8093\nWorkshopService" as IWk

' Conexiones (ball = provee, socket = requiere)
' Gateway provee HTTP
Gateway --( IHttp

' Browser requiere HTTP
Browser -- IHttp

' Microservicios proveen gRPC
AttSvc --( IAtt
AgSvc --( IAg
WkSvc --( IWk

' Gateway requiere los 3 servicios
AttStub -- IAtt
AgStub -- IAg
WkStub -- IWk

' Gateway usa stubs internamente
Gateway --> AttStub : <<use>>
Gateway --> AgStub : <<use>>
Gateway --> WkStub : <<use>>

' Servidores usan sus BD
AttSvc --> AttDb : <<use>>
AgSvc --> AgDb : <<use>>
WkSvc --> WkDb : <<use>>

@enduml
