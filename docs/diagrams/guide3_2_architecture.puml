@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Guide 3.2 - MovieHttpServer Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":Browser / curl" as Browser
}

package "«subsystem» MovieHttpServer" {
  component ":MovieHttpServer" as HttpServer
  component ":MovieRepository" as MovieRepo
  component ":Movie" as MovieModel
}

' Provided interfaces
interface "HTTP :8080" as IHttp

' Conexiones (ball = provee, socket = requiere)
' MovieHttpServer provee HTTP
HttpServer --( IHttp

' Browser requiere HTTP
Browser -- IHttp

' HttpServer usa repositorio
HttpServer --> MovieRepo : <<use>>

' Repositorio contiene modelo
MovieRepo --> MovieModel : <<use>>

@enduml
