@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Guide 4.2 - MovieService RMI Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":MovieRmiClient" as Client
}

package "«subsystem» MovieServer" {
  component ":MovieRmiServer" as Server
  component ":MovieServiceImpl" as ServiceImpl
  component ":MovieService\n(interface)" as ServiceInterface
  component ":Movie" as MovieModel
}

' Provided interfaces
interface "RMI Registry :23000\n(movieService)" as IRmi

' Conexiones (ball = provee, socket = requiere)
' Server provee servicio RMI
Server --( IRmi

' Cliente requiere RMI
Client -- IRmi

' Server registra implementacion
Server --> ServiceImpl : <<bind>>

' ServiceImpl implementa interfaz remota
ServiceImpl --> ServiceInterface : extends UnicastRemoteObject\nimplements MovieService

' ServiceImpl contiene BD interna (Map)
ServiceImpl --> MovieModel : <<in-memory map>>

@enduml
