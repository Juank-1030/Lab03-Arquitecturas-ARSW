@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Guide 5.2 - MovieService gRPC Architecture

' Subsistemas
package "«subsystem» Client" {
  component ":MovieGrpcClient" as Client
}

package "«subsystem» MovieGrpcServer" {
  component ":MovieServiceImpl" as ServiceImpl
  component ":movie.proto\n(GetMovie)" as ProtoFile
  database ":Movies Map\n(in memory)" as MovieDb
}

' Provided interfaces
interface "gRPC :50051\nMovieService" as IGrpc

' Conexiones (ball = provee, socket = requiere)
' ServiceImpl provee gRPC
ServiceImpl --( IGrpc

' Client requiere gRPC
Client -- IGrpc

' Proto define el contrato
ProtoFile --> IGrpc : <<defines>>

' ServiceImpl usa BD interna
ServiceImpl --> MovieDb : <<use>>

@enduml
