@startuml
skinparam componentStyle rectangle
skinparam backgroundColor white
skinparam defaultTextAlignment center

skinparam component {
  BackgroundColor #FFFEF0
  BorderColor #888888
  FontSize 13
  FontStyle bold
  ArrowColor #555555
}

skinparam interface {
  BackgroundColor white
  BorderColor #555555
}

skinparam arrow {
  Color #555555
  FontSize 11
}

title Guide 7.2 - MovieGateway Architecture

' Subsistemas
package "«subsystem» MovieGateway" {
  component ":MovieGateway\n(Console)" as Gateway
  component ":MovieStub gRPC" as MovieStub
  component ":ReviewStub gRPC" as ReviewStub
  component ":RecStub gRPC" as RecStub
}

package "«subsystem» MovieService" {
  component ":MovieServiceImpl" as MovieSvc
  database ":Movies Map" as MovieDb
}

package "«subsystem» ReviewService" {
  component ":ReviewServiceImpl" as ReviewSvc
  database ":Reviews Map" as ReviewDb
}

package "«subsystem» RecommendationService" {
  component ":RecommendationServiceImpl" as RecSvc
  database ":Recommendations Map" as RecDb
}

' Provided interfaces
interface "gRPC :50051\nMovieService" as IMovie
interface "gRPC :50052\nReviewService" as IReview
interface "gRPC :50053\nRecommendationService" as IRec

' Conexiones (ball = provee, socket = requiere)
' Microservicios proveen gRPC
MovieSvc --( IMovie
ReviewSvc --( IReview
RecSvc --( IRec

' Gateway requiere los 3 servicios via stubs
MovieStub -- IMovie
ReviewStub -- IReview
RecStub -- IRec

' Gateway usa stubs internamente
Gateway --> MovieStub : <<use>>
Gateway --> ReviewStub : <<use>>
Gateway --> RecStub : <<use>>

' Servidores usan sus BD
MovieSvc --> MovieDb : <<use>>
ReviewSvc --> ReviewDb : <<use>>
RecSvc --> RecDb : <<use>>

@enduml
